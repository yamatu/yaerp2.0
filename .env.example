# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=yaerp
POSTGRES_USER=yaerp
POSTGRES_PASSWORD=yaerp_secret_2024

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2024

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=yaerp_minio
MINIO_SECRET_KEY=minio_secret_2024
MINIO_BUCKET=yaerp
MINIO_USE_SSL=false

# JWT
JWT_SECRET=yaerp-jwt-secret-change-me-in-production
JWT_EXPIRE_HOURS=24
JWT_REFRESH_HOURS=168

# Authentication and browser origins
ALLOW_PUBLIC_REGISTRATION=false
# Set explicit production origins, separated by commas. Use * only for local development.
CORS_ALLOWED_ORIGINS=http://localhost:5555,http://127.0.0.1:5555,http://localhost:3000,http://127.0.0.1:3000

# Backend
BACKEND_PORT=8080
GIN_MODE=release

# Automatic PostgreSQL backups. BACKUP_HOST_DIR is a host-system path mounted
# into the backend container at BACKUP_DIRECTORY.
BACKUP_AUTO_ENABLED=true
BACKUP_HOST_DIR=./backups
BACKUP_DIRECTORY=/backups
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws

# WhatsApp Web sidecar
WHATSAPP_SERVICE_URL=http://whatsapp:3010
WHATSAPP_INTERNAL_SECRET=replace-with-a-long-random-secret
WHATSAPP_MAX_MEDIA_BYTES=26214400
