  },
  "bugs": {
    "url": "https://github.com/dream-num/univer-presets/issues"
  },
  "keywords": [
    "univer"
  ],
  "exports": {
    ".": {
      "import": "./lib/es/index.js",
      "require": "./lib/cjs/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./*": {
      "import": "./lib/es/*",
      "require": "./lib/cjs/*",
      "types": "./lib/types/index.d.ts"
    },
    "./worker": {
      "import": "./lib/es/worker.js",
      "require": "./lib/cjs/locales/*.js",
      "types": "./lib/types/worker.d.ts"
    },
    "./locales/*": {
      "import": "./lib/es/locales/*.js",
      "require": "./lib/cjs/locales/*.js",
      "types": "./lib/types/locales/*.d.ts"
    },
    "./lib/*": "./lib/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./lib/es/index.js",
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "peerDependencies": {
    "react": "^16.9.0 || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.9.0 || ^17.0.0 || ^18.0.0",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@univerjs/design": "0.5.0",
    "@univerjs/docs": "0.5.0",
    "@univerjs/docs-ui": "0.5.0",
    "@univerjs/engine-formula": "0.5.0",
    "@univerjs/engine-render": "0.5.0",
    "@univerjs/facade": "0.5.0",
    "@univerjs/rpc": "0.5.0",
    "@univerjs/sheets": "0.5.0",
    "@univerjs/sheets-formula": "0.5.0",
    "@univerjs/sheets-formula-ui": "0.5.0",
    "@univerjs/sheets-numfmt": "0.5.0",
    "@univerjs/sheets-numfmt-ui": "0.5.0",
    "@univerjs/sheets-ui": "0.5.0",
    "@univerjs/ui": "0.5.0"
  },
  "devDependencies": {
    "@univerjs/core": "0.5.0",
    "typescript": "^5.6.3",
    "@univerjs-infra/shared": "0.5.0"
  },
  "scripts": {
    "prebuild": "tsx prepare.ts",
    "build:preset": "tsx build.ts"
  },
  "module": "./lib/es/index.js"
}